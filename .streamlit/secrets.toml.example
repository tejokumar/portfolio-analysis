# Streamlit Cloud secrets template.
# Copy to .streamlit/secrets.toml for local testing, or paste into the
# "Secrets" pane in share.streamlit.io for production.
#
# DO NOT commit secrets.toml — it is gitignored.

# Password gate — two tiers
owner_password = "your-private-password"   # unlocks the Dashboard (your portfolio)
app_password = "guest-password-for-friends" # everything EXCEPT the Dashboard

# Brokerage (read-only)
SNAPTRADE_CLIENT_ID = ""
SNAPTRADE_CONSUMER_KEY = ""
SNAPTRADE_USER_ID = ""
SNAPTRADE_USER_SECRET = ""

# Market data
FMP_API_KEY = ""
POLYGON_API_KEY = ""

# AI / sentiment
GROK_API_KEY = ""
ANTHROPIC_API_KEY = ""
